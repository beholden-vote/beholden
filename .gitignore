# Node / web
node_modules/
web/dist/
*.local
.vite/

# Python / ETL
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
/build/
pipelines/build/
# NOTE: keep this anchored — a bare `build/` would also ignore the
# beholden_etl/build source package.

# ETL + tile pipeline artifacts (data is rebuilt, never committed)
/dist/
/data/
*.duckdb
*.duckdb.wal
*.pmtiles
*.mbtiles
spike/out/
spike/*.geojson
spike/*.fgb

# Secrets / local env
.env
.env.*
!.env.example
*.pem

# Local agent/tooling state (never commit)
.claude/

# graphify — commit graph.json / GRAPH_REPORT.md / graph.html as repo context;
# ignore machine-specific interpreter path, scan root, and transient build state.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_*.json
graphify-out/.needs_update
graphify-out/cost.json
graphify-out/cache/
graphify-out/20*/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
